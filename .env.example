# QSC Atlas - environment variables
# Copy this file to ".env" and fill in the secrets. The .env file is gitignored
# and must NEVER be committed or shared. The database IDs below are not secret.

# Notion integration token (the one secret for the site).
# Create it at: Notion -> Settings -> Connections -> "Develop or manage integrations"
# -> New integration (Internal). Copy the "Internal Integration Secret".
# THEN share the "QSC Data Analysis 26" page (or each database) with the integration.
NOTION_TOKEN=

# Fixed Notion data source (collection) IDs - no need to change these.
NOTION_DB_COUNTRIES=562cfd22-fff9-422e-9683-83c14642b49f
NOTION_DB_DOCUMENTS=a93c0811-fce2-4c11-b2ab-1c58998317b1
NOTION_DB_BLOG=63e55bb6-8faa-4963-88ab-a5d2c2f1fe99

# Firecrawl (web scraping for the QSC document scraper).
# Get a key at https://firecrawl.dev (free tier is enough to start).
FIRECRAWL_API_KEY=
# Optional: if you self-host Firecrawl, set its base URL here instead of using the cloud.
FIRECRAWL_BASE_URL=

# Vercel deploy hook URL (set after deploy). The scraper POSTs here to rebuild the
# site after it publishes low-risk document additions.
DEPLOY_HOOK_URL=
