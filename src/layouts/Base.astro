---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'QSC Atlas',
  description = 'How governments are migrating to quantum-safe cryptography, country by country.',
} = Astro.props;

const pageTitle = title === 'QSC Atlas' ? title : `${title} - QSC Atlas`;

const nav = [
  { href: '/map', label: 'Map' },
  { href: '/countries', label: 'Countries' },
  { href: '/methodology', label: 'Methodology' },
  { href: '/documents', label: 'Documents' },
  { href: '/about', label: 'About' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
const buildDate = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,400;0,500;0,600;1,400&family=Schibsted+Grotesk:wght@400;500;600;700&family=Spline+Sans+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <a class="wordmark" href="/">QSC Atlas</a>
      <nav class="site-nav" aria-label="Primary">
        {nav.map((item) => <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>)}
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-brand">
        <img class="ceps-logo" src="/ceps-logo.png" alt="CEPS" width="240" height="262" loading="lazy" />
        <span class="footer-year mono">&copy; 2026</span>
      </div>
      <p class="footer-asof mono">As of {buildDate}</p>
    </footer>

    <style>
      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-6);
        height: var(--header-h);
        padding: 0 var(--space-6);
        border-bottom: 1px solid var(--hairline);
      }
      .wordmark {
        font-weight: 600;
        letter-spacing: 0.02em;
        text-decoration: none;
        font-size: 1.1rem;
      }
      .site-nav {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-4);
        font-size: 0.95rem;
      }
      .site-nav a {
        color: var(--ink-muted);
        text-decoration: none;
      }
      .site-nav a:hover {
        color: var(--ink);
      }
      .site-nav a[aria-current='page'] {
        color: var(--ink);
        text-decoration: underline;
        text-decoration-color: var(--hairline);
        text-underline-offset: 5px;
      }
      main {
        min-height: 60vh;
        flex: 1 0 auto; /* grow so the footer is pushed to the very bottom of the page */
      }
      .site-footer {
        margin-top: var(--space-16);
        padding: var(--space-10) var(--space-6);
        border-top: 1px solid var(--hairline);
        color: var(--ink-muted);
        font-size: 0.9rem;
        text-align: center;
      }
      .footer-brand {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-2);
      }
      .ceps-logo {
        height: 56px;
        width: auto;
        display: block;
      }
      .footer-year {
        font-size: 0.8rem;
        color: var(--ink-faint);
        letter-spacing: 0.04em;
      }
      .footer-asof {
        margin: var(--space-4) 0 0;
        font-size: 0.78rem;
        color: var(--ink-faint);
      }
    </style>
  </body>
</html>
