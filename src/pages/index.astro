---
import { createRequire } from 'node:module';
import Base from '../layouts/Base.astro';
import HeroGlobe from '../components/HeroGlobe';
import { getCollection } from 'astro:content';

// The homepage as two calm screens. The first is the title and the globe alone, centred and
// filling the viewport, with a quiet cue to scroll. The second states what the Atlas is in plain
// language and offers two understated ways on: the map and the explanation. Native scroll only.
const require = createRequire(import.meta.url);
let worldCountries: any = require('world-countries');
if (!Array.isArray(worldCountries)) worldCountries = worldCountries.default ?? [];
const CCN3: Record<string, string> = Object.fromEntries(worldCountries.map((c: any) => [c.cca3, c.ccn3]));

const countries = await getCollection('countries');
const mapProcess: Record<string, any> = {};
for (const c of countries) {
  const d = c.data;
  if (!d.coordinationPosture) continue;
  const ccn3 = CCN3[d.iso3];
  if (ccn3) mapProcess[String(Number(ccn3))] = { iso3: d.iso3, name: d.country, posture: d.coordinationPosture, role: d.standardsRole ?? null, confidence: d.confidence ?? null };
}
---

<Base
  title="The geopolitics of the post-quantum transition"
  description="A plain, evidence-based map of how countries are switching to quantum-safe encryption, and how ready each one is. Built only from official sources."
>
  <section class="hero" aria-labelledby="hero-title">
    <h1 id="hero-title">The geopolitics of the post-quantum transition</h1>
    <div class="globe-box"><HeroGlobe client:idle mapProcess={mapProcess} /></div>
    <a class="scroll-cue" href="#more">
      <span>Scroll</span>
      <svg viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
        <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
  </section>

  <section class="intro" id="more" aria-labelledby="intro-lede">
    <div class="intro-inner">
      <p class="lede" id="intro-lede">
        Modern encryption protects almost everything online. A powerful enough quantum computer could
        one day break it, so the world is quietly switching to new, quantum-safe encryption. The QSC
        Atlas maps how far each country has got, and how ready it really is.
      </p>
      <div class="actions">
        <a class="btn" href="/map">Open the map</a>
        <a class="btn" href="/commentary">More information</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Screen one: the title and the globe, alone. Header plus hero fill exactly one viewport. */
  .hero {
    min-height: calc(100svh - var(--header-h));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
    text-align: center;
    padding: var(--space-8) var(--space-6) var(--space-12);
    position: relative;
  }
  h1 {
    font-family: var(--font-reading);
    font-weight: 500;
    font-size: var(--type-display);
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin: 0;
    max-width: 18ch;
  }
  .globe-box {
    width: min(62vmin, 34rem);
    aspect-ratio: 1 / 1;
  }
  .globe-box > * {
    width: 100%;
    height: 100%;
    display: block;
  }
  .globe-box :global(.hg-controls) {
    display: none;
  }

  /* A quiet affordance that the page continues below. Clicking it scrolls to screen two. */
  .scroll-cue {
    position: absolute;
    bottom: var(--space-5);
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-label);
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-faint);
    text-decoration: none;
  }
  .scroll-cue:hover {
    color: var(--ink);
  }
  @media (prefers-reduced-motion: no-preference) {
    .scroll-cue svg {
      animation: cue 1.9s var(--ease, ease-in-out) infinite;
    }
  }
  @keyframes cue {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(3px); }
  }

  /* Screen two: the plain-language statement, then two understated ways on. */
  .intro {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-16) var(--space-6);
    border-top: 1px solid var(--hairline);
  }
  .intro-inner {
    max-width: 40rem;
    text-align: center;
  }
  .lede {
    font-family: var(--font-reading);
    font-size: clamp(1.25rem, 1rem + 1.1vw, 1.6rem);
    line-height: var(--leading-normal);
    color: var(--ink);
    margin: 0 0 var(--space-9);
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }
  /* Subtle by default: a hairline outline and muted ink, settling to full ink on hover or focus.
     No filled button competes for attention now that the map is one of two equal, quiet choices. */
  .btn {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: var(--space-2) var(--space-5);
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    font-family: var(--font-instrument);
    font-size: var(--text-sm);
    color: var(--ink-muted);
    text-decoration: none;
    transition: color var(--dur, 0.2s) var(--ease, ease), border-color var(--dur, 0.2s) var(--ease, ease);
  }
  .btn:hover {
    color: var(--ink);
    border-color: var(--ink);
  }
  .btn:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
  }

  /* Phones: the header stacks to roughly 10rem here (wordmark over a wrapped nav), so the hero
     reclaims that height to keep the title, globe and cue inside one screen. Globe and gap tighten. */
  @media (max-width: 700px) {
    .hero {
      min-height: calc(100svh - 10rem);
      gap: var(--space-5);
    }
    .globe-box {
      width: min(76vw, 22rem);
    }
  }
</style>
