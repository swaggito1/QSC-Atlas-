---
import { createRequire } from 'node:module';
import Base from '../layouts/Base.astro';
import HeroGlobe from '../components/HeroGlobe';
import { getCollection } from 'astro:content';

// The homepage, kept simple: a globe hero with a plain-language explainer and clear actions,
// then a short "at a glance" section that states all the content without detail and links out to
// the map, the method and the explanation. No pinned-scroll choreography.
const require = createRequire(import.meta.url);
let worldCountries: any = require('world-countries');
if (!Array.isArray(worldCountries)) worldCountries = worldCountries.default ?? [];
const CCN3: Record<string, string> = Object.fromEntries(worldCountries.map((c: any) => [c.cca3, c.ccn3]));

const countries = await getCollection('countries');
const mapProcess: Record<string, any> = {};
for (const c of countries) {
  const d = c.data;
  if (!d.coordinationPosture) continue;
  const ccn3 = CCN3[d.iso3];
  if (ccn3) mapProcess[String(Number(ccn3))] = { iso3: d.iso3, name: d.country, posture: d.coordinationPosture, role: d.standardsRole ?? null, confidence: d.confidence ?? null };
}
---

<Base
  title="The geopolitics of the post-quantum transition"
  description="A plain, evidence-based map of how countries are switching to quantum-safe encryption, and how ready each one is. Built only from official sources."
>
  <section class="hero">
    <div class="hero-text">
      <h1>The geopolitics of the post-quantum transition</h1>
      <p class="lede">
        Modern encryption protects almost everything online. A powerful enough quantum computer could
        one day break it, so the world is quietly switching to new, quantum-safe encryption. The QSC
        Atlas maps how far each country has got, and how ready it really is.
      </p>
      <div class="actions">
        <a class="btn btn--primary" href="/map">Open the map</a>
        <a class="btn" href="/commentary">More information</a>
      </div>
    </div>
    <div class="hero-globe">
      <div class="globe-box"><HeroGlobe client:idle mapProcess={mapProcess} /></div>
    </div>
  </section>

  <section class="glance">
    <article class="block">
      <h2>What it shows</h2>
      <p>
        For any country, the Atlas shows who it is switching alongside, which new encryption standards
        it uses, the rule that requires it to act, the deadline it works to, and how solid its plan
        looks. Every entry is drawn from official government and standards sources.
      </p>
      <a class="more" href="/map">Open the map &rarr;</a>
    </article>

    <article class="block">
      <h2>How it reads each country</h2>
      <p>
        Two things are easy to confuse, so the Atlas keeps them apart. The first is the group a
        country is migrating with, shown by the colour on the map. The second is what it does with the
        standards, whether it helps write them, adapts them, simply adopts them, or builds its own,
        shown on each country's page.
      </p>
      <a class="more" href="/methodology">See the full method &rarr;</a>
    </article>

    <article class="block">
      <h2>Why it matters</h2>
      <p>
        No single authority is in charge of this change. One set of standards now sits underneath
        almost every national plan, but the rules, deadlines and instruments around it differ from
        country to country. That makes the switch uneven, and increasingly a question of power.
      </p>
      <a class="more" href="/commentary">Read the explanation &rarr;</a>
    </article>
  </section>
</Base>

<style>
  /* Hero: plain-language explainer beside the globe. */
  .hero {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: var(--space-10) var(--space-6) var(--space-8);
    display: grid;
    grid-template-columns: minmax(0, 32rem) minmax(0, 1fr);
    gap: var(--space-10);
    align-items: center;
  }
  .hero-text {
    min-width: 0;
  }
  h1 {
    font-family: var(--font-reading);
    font-weight: 500;
    font-size: clamp(1.9rem, 1.2rem + 2.2vw, 3rem);
    line-height: 1.06;
    letter-spacing: -0.015em;
    margin: 0 0 var(--space-5);
  }
  .lede {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--ink);
    margin: 0 0 var(--space-6);
    max-width: 34rem;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .btn {
    display: inline-block;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    padding: var(--space-3) var(--space-5);
    font-family: var(--font-instrument);
    font-size: var(--text-sm);
    color: var(--ink);
    text-decoration: none;
    transition: background var(--dur, 0.2s) var(--ease, ease), color var(--dur, 0.2s) var(--ease, ease);
  }
  .btn:hover {
    background: var(--ink);
    color: var(--paper);
  }
  .btn--primary {
    background: var(--ink);
    color: var(--paper);
  }
  .btn--primary:hover {
    background: transparent;
    color: var(--ink);
  }
  .hero-globe {
    min-width: 0;
  }
  .globe-box {
    width: min(100%, 40rem);
    aspect-ratio: 1 / 1;
    margin-inline: auto;
  }
  .globe-box > * {
    width: 100%;
    height: 100%;
    display: block;
  }
  .globe-box :global(.hg-controls) {
    display: none;
  }

  /* At a glance: all the content, plainly, with a link onward from each. */
  .glance {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: var(--space-10) var(--space-6) var(--space-16);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
    border-top: 1px solid var(--hairline);
  }
  .block h2 {
    font-family: var(--font-reading);
    font-weight: 500;
    font-size: var(--text-xl);
    margin: 0 0 var(--space-3);
  }
  .block p {
    margin: 0 0 var(--space-4);
    color: var(--ink-muted);
  }
  .more {
    font-family: var(--font-instrument);
    font-size: var(--text-sm);
    color: var(--ink);
    text-underline-offset: 3px;
    text-decoration-color: var(--hairline);
  }
  .more:hover {
    text-decoration-color: var(--ink);
  }

  @media (max-width: 960px) {
    .hero {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      padding-top: var(--space-8);
    }
    .hero-globe {
      order: -1;
    }
    .globe-box {
      width: min(72vw, 340px);
    }
    .glance {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
