---
import { createRequire } from 'node:module';
import Base from '../layouts/Base.astro';
import AtlasMap from '../components/AtlasMap';
import ProcessLegend from '../components/ProcessLegend.astro';
import { getCollection } from 'astro:content';

// The map is the hero. It is keyed by ISO numeric code (ccn3), which matches the
// world-atlas topojson country ids. Build that lookup from countries that have a
// dominant standards process. Clicking a country slides its profile in.
const require = createRequire(import.meta.url);
let worldCountries: any = require('world-countries');
if (!Array.isArray(worldCountries)) worldCountries = worldCountries.default ?? [];
const CCN3: Record<string, string> = Object.fromEntries(
  worldCountries.map((c: any) => [c.cca3, c.ccn3]),
);

const countries = await getCollection('countries');
const allDocs = await getCollection('documents');

const mapProcess: Record<string, { iso3: string; name: string; process: string }> = {};
const profiles: Record<string, any> = {};
for (const c of countries) {
  const d = c.data;
  profiles[d.iso3] = {
    iso3: d.iso3,
    country: d.country,
    summary: d.summary,
    govActors: d.govActors,
    standardFamilies: d.standardFamilies,
    algorithms: d.algorithms,
    dominantProcess: d.dominantProcess,
    processParticipation: d.processParticipation,
    hybridDeployment: d.hybridDeployment,
    migrationTimeline: d.migrationTimeline,
    targetCompletion: d.targetCompletion,
    lastUpdated: d.lastUpdated,
  };
  if (d.dominantProcess) {
    const ccn3 = CCN3[d.iso3];
    if (ccn3) mapProcess[String(Number(ccn3))] = { iso3: d.iso3, name: d.country, process: d.dominantProcess };
  }
}

// Key documents per country (ISO3), most important tier first, capped for the panel.
const TIER_RANK: Record<string, number> = { T1: 0, T2: 1, T3: 2, T4: 3 };
const documents: Record<string, any[]> = {};
for (const doc of allDocs) {
  const iso = (doc.data.country ?? '').toUpperCase();
  if (!iso) continue;
  (documents[iso] ??= []).push({
    title: doc.data.title,
    issuingOrg: doc.data.issuingOrg,
    year: doc.data.year,
    tier: doc.data.tier,
    url: doc.data.url,
  });
}
for (const iso of Object.keys(documents)) {
  documents[iso].sort((a, b) => (TIER_RANK[a.tier] ?? 9) - (TIER_RANK[b.tier] ?? 9));
  documents[iso] = documents[iso].slice(0, 12);
}

const withData = Object.keys(mapProcess).length;
---

<Base title="QSC Atlas">
  <section class="map-wrap">
    <AtlasMap client:load mapProcess={mapProcess} profiles={profiles} documents={documents} />

    <p class="caption prose">
      The world is splitting into cryptographic standards camps with different deadlines.
      Each country is coloured by the standards process it aligns with.
    </p>

    <div class="legend-row">
      <div>
        <p class="legend-title">Legend</p>
        <ProcessLegend />
      </div>
      <p class="count mono">{withData} countries with data</p>
    </div>
  </section>
</Base>

<style>
  .map-wrap {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: var(--space-6) var(--space-6) var(--space-8);
  }
  .caption {
    margin: var(--space-5) 0 0;
    color: var(--ink-muted);
  }
  .legend-row {
    margin-top: var(--space-6);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  .legend-title {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-muted);
    font-weight: 600;
    margin: 0 0 var(--space-3);
  }
  .count {
    font-size: var(--text-xs);
    color: var(--ink-faint);
  }
</style>
