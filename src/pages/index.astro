---
import { createRequire } from 'node:module';
import Base from '../layouts/Base.astro';
import HeroGlobe from '../components/HeroGlobe';
import { getCollection } from 'astro:content';

// The homepage: a pinned globe that holds the screen and slides side to side as you scroll, while
// text takes the other half with no overlap. Two beats. First the globe sits centred under the
// title alone; then it sweeps to the right and the plain-language lede and two quiet actions take
// the left. Native scroll drives an IntersectionObserver that sets body[data-scene]; CSS maps each
// scene to a globe pose. Stacks to plain blocks on small screens.
const require = createRequire(import.meta.url);
let worldCountries: any = require('world-countries');
if (!Array.isArray(worldCountries)) worldCountries = worldCountries.default ?? [];
const CCN3: Record<string, string> = Object.fromEntries(worldCountries.map((c: any) => [c.cca3, c.ccn3]));

const countries = await getCollection('countries');
const mapProcess: Record<string, any> = {};
for (const c of countries) {
  const d = c.data;
  if (!d.coordinationPosture) continue;
  const ccn3 = CCN3[d.iso3];
  if (ccn3) mapProcess[String(Number(ccn3))] = { iso3: d.iso3, name: d.country, posture: d.coordinationPosture, role: d.standardsRole ?? null, confidence: d.confidence ?? null };
}
---

<Base hideNav title="The geopolitics of the post-quantum transition" description="A plain, evidence-based map of how countries are switching to quantum-safe encryption, and how ready each one is. Built only from official sources.">
  <!-- The menu, drawn from the ui-ux-god glass nav + its pure-CSS scroll reveal: it stays out of the
       way at the top and rolls down into the corner as you scroll. Wide screens get an inline bar;
       phones get a small "Menu" disclosure that rolls the links down on tap (native details, no JS). -->
  <nav class="scroll-nav scroll-nav--bar" aria-label="Sections">
    <a href="/map">Map</a>
    <a href="/countries">Countries</a>
    <a href="/methodology">Methodology</a>
    <a href="/documents">Documents</a>
    <a href="/about">About</a>
  </nav>
  <details class="scroll-nav scroll-nav--menu">
    <summary>
      <span>Menu</span>
      <svg class="chev" viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6l4 4 4-4" /></svg>
    </summary>
    <nav aria-label="Sections">
      <a href="/map">Map</a>
      <a href="/countries">Countries</a>
      <a href="/methodology">Methodology</a>
      <a href="/documents">Documents</a>
      <a href="/about">About</a>
    </nav>
  </details>

  <main class="scrolly">
    <div class="globe-stage" data-scene="hero">
      <div class="globe-box">
        <HeroGlobe client:idle mapProcess={mapProcess} />
      </div>
    </div>

    <section class="scene scene--hero" data-scene="hero" aria-labelledby="s-hero">
      <div class="text">
        <h1 id="s-hero">The geopolitics of the post-quantum transition</h1>
      </div>
    </section>

    <section class="scene scene--right" data-scene="intro" aria-labelledby="s-intro">
      <div class="text">
        <p class="lede" id="s-intro">
          Modern encryption protects almost everything online. A powerful enough quantum computer could
          one day break it, so the world is quietly switching to new, quantum-safe encryption. The QSC
          Atlas maps how far each country has got, and how ready it really is.
        </p>
        <div class="actions">
          <a class="btn" href="/map">Open the map</a>
          <a class="btn" href="/commentary">More information</a>
        </div>
      </div>
    </section>

    <nav class="scroll-rail" aria-hidden="true">
      <a href="#s-hero" data-mark="hero"></a>
      <a href="#s-intro" data-mark="intro"></a>
    </nav>

    <!-- A subtle scroll hint by the globe's lower right, fading out as soon as you start scrolling. -->
    <div class="scroll-cue" aria-hidden="true">
      <svg viewBox="0 0 24 30" width="22" height="27" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 8l7 7 7-7" />
        <path d="M5 17l7 7 7-7" />
      </svg>
    </div>
  </main>

</Base>

<script>
  // Scene driver: native scroll only. The observer marks the active scene on body[data-scene]
  // (CSS reads it for the globe pose) and reveals each scene's text once. The choreography runs on
  // wide screens whether or not reduced motion is set, because the sliding globe is the site's
  // essential structure and is driven by the reader's own scroll (the globe's continuous auto-spin
  // stays off under reduced motion, handled inside the component). Narrow screens stack instead.
  const small = matchMedia('(max-width: 1200px)').matches;
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const scenes = Array.from(document.querySelectorAll('.scene'));
  const rail = Array.from(document.querySelectorAll('.scroll-rail a'));

  if (!small) {
    // A short trigger band across the vertical centre of the viewport. The scene whose body
    // crosses that band is the active one, which holds regardless of how tall a scene runs.
    const active = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          const scene = e.target.getAttribute('data-scene');
          if (!scene) continue;
          document.body.dataset.scene = scene;
          for (const a of rail) a.classList.toggle('is-active', a.getAttribute('data-mark') === scene);
        }
      },
      { rootMargin: '-45% 0px -45% 0px', threshold: 0 },
    );
    const reveal = new IntersectionObserver(
      (entries) => {
        for (const e of entries) if (e.isIntersecting) { e.target.classList.add('is-in'); reveal.unobserve(e.target); }
      },
      { threshold: 0.2 },
    );
    // Mark JS active (CSS only hides-then-reveals text when this is set) and show the hero at once.
    document.body.classList.add('is-scrolly');
    document.body.dataset.scene = 'hero';
    if (scenes[0]) scenes[0].classList.add('is-in');
    for (const s of scenes) { active.observe(s); reveal.observe(s); }
  } else {
    for (const s of scenes) s.classList.add('is-in');
  }

  for (const a of rail) {
    a.addEventListener('click', (ev) => {
      ev.preventDefault();
      const id = a.getAttribute('href');
      const el = id ? document.querySelector(id) : null;
      if (el) el.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'center' });
    });
  }
</script>

<style>
  .scrolly {
    position: relative;
  }

  /* The globe stage: pinned through-line, zoomed and posed per scene. */
  .globe-stage {
    position: sticky;
    top: 0;
    height: 100svh;
    display: grid;
    place-items: center;
    z-index: 0;
    transform: translateY(-7%) scale(0.58); /* hero pose by default, matches the JS hero pose */
    transition: transform var(--dur-slow) var(--ease-out), opacity var(--dur-mid) var(--ease-standard);
    will-change: transform, opacity;
  }
  .globe-box {
    width: min(108vw, 162svh);
    aspect-ratio: 1 / 1;
  }
  .globe-box > * {
    width: 100%;
    height: 100%;
    display: block;
  }
  .globe-box :global(.hg-controls) {
    display: none;
  }

  /* Centred and smaller at the hero; zoomed in and pushed to the right for the intro, so the globe
     sits up close on the right half with roughly 40% of it on screen and the rest beyond the edge.
     translateX is a share of the full stage width, so its magnitude sets how much of the globe stays
     visible: raise it to hide more, lower it to show more. */
  body[data-scene='hero'] .globe-stage {
    transform: translateY(-7%) scale(0.58);
    opacity: 1;
  }
  body[data-scene='intro'] .globe-stage {
    transform: translateX(50%) scale(1);
    opacity: 1;
  }

  .scene {
    position: relative;
    z-index: 1;
    min-height: var(--scene-min-h);
    display: grid;
    align-items: center;
    gap: var(--space-8);
    max-width: var(--content-wide);
    margin-inline: auto;
    padding: var(--space-8) var(--space-6);
    /* Let clicks fall through the scene to the globe behind it; only the text blocks catch them. */
    pointer-events: none;
  }
  .scene--hero {
    margin-top: -100svh;
    grid-template-columns: 1fr;
    justify-items: center;
    align-content: start;
    text-align: center;
    padding-top: 3vh;
  }
  .scene--hero .text {
    max-width: 46rem;
    padding: var(--space-8);
    /* a soft paper halo keeps the title legible where it layers over the centred globe */
    background: radial-gradient(62% 56% at 50% 42%, var(--paper) 0%, var(--paper) 46%, transparent 100%);
    /* Hero is title only: keep the whole centred globe behind it clickable. */
    pointer-events: none;
  }
  /* Globe to the right: text (lede and actions) holds the left half. */
  .scene--right {
    grid-template-columns: minmax(0, 34rem) 1fr;
  }
  .scene--right .text {
    grid-column: 1;
  }
  .scene .text {
    opacity: 1;
    transform: none;
    transition: opacity var(--dur-mid) var(--ease-standard), transform var(--dur-mid) var(--ease-out);
    pointer-events: auto;
    min-width: 0;
  }
  /* Hide-then-reveal only once JS is driving the scenes; without JS every text block stays visible. */
  body.is-scrolly .scene:not(.is-in) .text {
    opacity: 0;
    transform: translateY(16px);
  }

  h1 {
    font-family: var(--font-reading);
    font-weight: 500;
    font-size: var(--type-display);
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin: 0;
  }
  .lede {
    font-family: var(--font-reading);
    font-size: clamp(1.2rem, 1rem + 0.9vw, 1.5rem);
    line-height: var(--leading-normal);
    color: var(--ink);
    margin: 0;
  }

  /* Two understated actions: a hairline outline and muted ink, settling to full ink on hover or
     focus. Neither is filled; the map and the explanation are equal, quiet choices. */
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-7);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: var(--space-2) var(--space-5);
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    font-family: var(--font-instrument);
    font-size: var(--text-sm);
    color: var(--ink-muted);
    text-decoration: none;
    transition: color var(--dur, 0.2s) var(--ease, ease), border-color var(--dur, 0.2s) var(--ease, ease);
  }
  .btn:hover {
    color: var(--ink);
    border-color: var(--ink);
  }
  .btn:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
  }

  .scroll-rail {
    position: fixed;
    top: 50%;
    right: var(--space-5);
    transform: translateY(-50%);
    display: grid;
    gap: var(--space-3);
    z-index: 5;
  }
  .scroll-rail a {
    width: var(--rail-w);
    height: 28px;
    background: var(--hairline);
    display: block;
  }
  .scroll-rail a.is-active {
    background: var(--ink);
  }

  /* The rolling menu, drawn from the ui-ux-god glass nav + its pure-CSS scroll reveal. It is out of
     the way at the very top so the title and globe stand alone, then rolls down into the corner as
     you begin scrolling. Shared shell: fixed top-left, frosted glass, scroll-driven reveal. */
  .scroll-nav {
    position: fixed;
    top: var(--space-3);
    left: var(--space-4);
    z-index: 50;
    border: 1px solid var(--hairline);
    background: color-mix(in srgb, var(--paper) 72%, transparent);
    -webkit-backdrop-filter: blur(14px) saturate(1.5);
    backdrop-filter: blur(14px) saturate(1.5);
    animation: nav-roll linear both;
    animation-timeline: scroll(root block);
    animation-range: 5vh 24vh;
  }
  @keyframes nav-roll {
    from { opacity: 0; transform: translateY(-160%); }
    to { opacity: 1; transform: translateY(0); }
  }
  /* Keyboard users reach the menu regardless of scroll: focusing it forces it fully into view. */
  .scroll-nav:focus-within {
    opacity: 1 !important;
    transform: none !important;
    animation: none;
  }
  .scroll-nav a {
    font-family: var(--font-instrument);
    font-size: var(--text-xs);
    line-height: 1;
    color: var(--ink-muted);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border-radius: 999px;
    white-space: nowrap;
    transition: color var(--dur, 0.2s) var(--ease, ease), background var(--dur, 0.2s) var(--ease, ease);
  }
  .scroll-nav a:hover {
    color: var(--ink);
    background: color-mix(in srgb, var(--ink) 7%, transparent);
  }
  .scroll-nav a:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
  }

  /* Wide screens: the inline bar, links in a row inside a glass pill. */
  .scroll-nav--bar {
    display: flex;
    gap: 2px;
    padding: 4px;
    border-radius: 999px;
  }
  .scroll-nav--menu {
    display: none;
  }

  /* Phones: a small "Menu" disclosure that rolls the links down on tap. Native details, no script. */
  @media (max-width: 640px) {
    .scroll-nav--bar {
      display: none;
    }
    .scroll-nav--menu {
      display: block;
      border-radius: var(--radius);
      overflow: hidden;
      /* a touch more opaque than the desktop bar, since the open panel overlays the globe */
      background: color-mix(in srgb, var(--paper) 85%, transparent);
    }
    .scroll-nav--menu summary {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-2) var(--space-3);
      list-style: none;
      cursor: pointer;
      font-family: var(--font-instrument);
      font-size: var(--text-xs);
      color: var(--ink-muted);
    }
    .scroll-nav--menu summary::-webkit-details-marker {
      display: none;
    }
    .scroll-nav--menu summary:hover {
      color: var(--ink);
    }
    .scroll-nav--menu summary:focus-visible {
      outline: 2px solid var(--ink);
      outline-offset: 2px;
      border-radius: var(--radius);
    }
    .scroll-nav--menu .chev {
      color: var(--ink-faint);
      transition: transform var(--dur, 0.2s) var(--ease, ease);
    }
    .scroll-nav--menu[open] .chev {
      transform: rotate(180deg);
    }
    .scroll-nav--menu[open] nav {
      display: flex;
      flex-direction: column;
      padding: 0 4px 4px;
      animation: menu-open var(--dur, 0.22s) var(--ease, ease);
    }
    /* Comfortable 44px tap rows on phones. */
    .scroll-nav--menu nav a {
      display: flex;
      align-items: center;
      min-height: 44px;
      padding: var(--space-2) var(--space-4);
    }
  }
  @keyframes menu-open {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Reduced motion: reveal by fade alone, no vertical travel. */
  @media (prefers-reduced-motion: reduce) {
    @keyframes nav-roll { from { opacity: 0; } to { opacity: 1; } }
    @keyframes menu-open { from { opacity: 0; } to { opacity: 1; } }
  }
  /* Where scroll-driven animation is unsupported, the menu simply stays visible in the corner. */
  @supports not (animation-timeline: scroll()) {
    .scroll-nav { animation: none; opacity: 1; transform: none; }
  }

  /* A subtle scroll hint by the globe's lower right on the first beat: a faint double chevron that
     nudges down and fades out as soon as you begin scrolling. */
  .scroll-cue {
    position: fixed;
    bottom: var(--space-8);
    right: var(--space-10);
    z-index: 40;
    color: var(--ink-faint);
    pointer-events: none;
    animation: cue-fade linear both;
    animation-timeline: scroll(root block);
    animation-range: 0 14vh;
  }
  @keyframes cue-fade { from { opacity: 0.75; } to { opacity: 0; } }
  @keyframes cue-bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(5px); } }
  @media (prefers-reduced-motion: no-preference) {
    .scroll-cue {
      animation: cue-fade linear both, cue-bob 1.9s ease-in-out infinite;
      animation-timeline: scroll(root block), auto;
      animation-range: 0 14vh, normal;
    }
  }
  @supports not (animation-timeline: scroll()) {
    .scroll-cue { animation: none; opacity: 0.5; }
  }

  /* Stacked fallback: narrow screens drop the pinned, zoomed stage for a clean static layout. The
     enlarged globe plus a full text column only fit side by side on wide screens; below the
     threshold the globe is resized to a modest size and stacked above the text. */
  @media (max-width: 1200px) {
    .globe-stage {
      position: static;
      height: auto;
      transform: none !important;
      opacity: 1 !important;
      padding: var(--space-8) var(--space-6) 0;
    }
    .globe-box {
      width: min(72vw, 460px);
      margin-inline: auto;
    }
    .scene {
      grid-template-columns: 1fr !important;
      min-height: 0;
      padding-block: var(--space-10);
      text-align: left;
    }
    .scene--hero {
      margin-top: 0;
      padding-top: var(--space-8);
      text-align: left;
      justify-items: start;
    }
    .scene--hero .text {
      background: none; /* the paper halo is only needed when the title overlays the globe */
    }
    .scene .text {
      opacity: 1;
      transform: none;
      grid-column: 1 !important;
    }
    .scroll-rail {
      display: none;
    }
  }
</style>
