---
import { createRequire } from 'node:module';
import Base from '../layouts/Base.astro';
import HeroGlobe from '../components/HeroGlobe';
import { getCollection } from 'astro:content';
import { POSTURE_ORDER, POSTURE_META } from '../lib/process';

// One-page Atlas: a globe hero, then bands for countries, analysis, documents and
// about, each linking to its full page. The globe is keyed by ccn3 (topojson ids).
const require = createRequire(import.meta.url);
let worldCountries: any = require('world-countries');
if (!Array.isArray(worldCountries)) worldCountries = worldCountries.default ?? [];
const CCN3: Record<string, string> = Object.fromEntries(worldCountries.map((c: any) => [c.cca3, c.ccn3]));

const countries = await getCollection('countries');
const docs = await getCollection('documents');
const posts = (await getCollection('blog')).sort((a, b) => (b.data.published ?? '').localeCompare(a.data.published ?? ''));

const mapProcess: Record<string, any> = {};
for (const c of countries) {
  const d = c.data;
  if (!d.coordinationPosture) continue;
  const ccn3 = CCN3[d.iso3];
  if (ccn3) mapProcess[String(Number(ccn3))] = { iso3: d.iso3, name: d.country, posture: d.coordinationPosture, role: d.standardsRole ?? null, confidence: d.confidence ?? null };
}

const blocGroups = POSTURE_ORDER.map((p) => ({ meta: POSTURE_META[p], count: countries.filter((c) => c.data.coordinationPosture === p).length })).filter((g) => g.count);
const classified = countries.filter((c) => c.data.coordinationPosture).length;
const docCount = docs.length;
const latest = posts[0]?.data ?? null;
---

<Base title="QSC Atlas" description="Quantum-safe cryptography: the quiet migration reshaping digital sovereignty">
  <section class="hero">
    <div class="hero-text">
      <p class="hero-lede">
        Quantum-safe cryptography:<br class="lede-break" /> the quiet migration reshaping digital sovereignty
      </p>
      <p class="hero-hint mono">
        Click a country to open it. <a href="/map">Open the flat map &rarr;</a>
      </p>
    </div>
    <div class="hero-globe">
      <HeroGlobe client:load mapProcess={mapProcess} />
    </div>
  </section>

  <section class="band" id="countries">
    <div class="band-head"><h2>Countries</h2><a href="/countries">All countries &rarr;</a></div>
    <p class="band-lede">{countries.length} profiles, {classified} placed in a coordination bloc.</p>
    <ul class="bloc-counts">
      {blocGroups.map((g) => (
        <li style={`--c:${g.meta.color}`}><span class="sw" aria-hidden="true" />{g.meta.label}<span class="n mono">{g.count}</span></li>
      ))}
    </ul>
  </section>

  <section class="band" id="analysis">
    <div class="band-head"><h2>Analysis</h2><a href="/analysis">All analysis &rarr;</a></div>
    {
      latest ? (
        <a class="latest" href={`/analysis/${latest.slug}`}>
          <span class="latest-title">{latest.title}</span>
          {latest.published && <span class="latest-date mono">{latest.published}</span>}
        </a>
      ) : (
        <p class="band-lede">Commentary and change notes on the quantum-safe transition.</p>
      )
    }
  </section>

  <section class="band" id="documents">
    <div class="band-head"><h2>Documents</h2><a href="/documents">Search the documents &rarr;</a></div>
    <p class="band-lede">
      {docCount} institutional sources behind the Atlas, searchable by title and filterable by
      country, type, year and tier.
    </p>
  </section>

  <section class="band" id="about">
    <div class="band-head"><h2>About</h2><a href="/about">About and methodology &rarr;</a></div>
    <p class="band-lede">
      How the Atlas classifies countries on two dimensions, the coordination bloc and the
      standards role, and how the data is gathered. Built only from institutional sources,
      rebuilt as new documents appear.
    </p>
    <p><a class="briefing" href="/about#briefing">Request a briefing &rarr;</a></p>
  </section>
</Base>

<style>
  .hero {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: var(--space-6);
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: var(--space-6);
    align-items: stretch;
    height: calc(100svh - var(--header-h));
  }
  .hero-text {
    justify-self: start;
    align-self: center;
  }
  .hero-globe {
    min-width: 0;
    height: 100%;
  }
  .hero-lede {
    font-family: var(--font-reading);
    font-size: clamp(1.45rem, 0.6rem + 1.35vw, 1.75rem);
    line-height: var(--leading-snug);
    color: var(--ink);
    margin: 0 0 var(--space-6);
    text-wrap: normal;
  }
  @media (max-width: 860px) {
    .hero-lede {
      font-size: clamp(1.5rem, 1rem + 1.9vw, 2.4rem);
      text-wrap: pretty;
    }
    .hero-lede .lede-break {
      display: none;
    }
  }
  .hero-hint {
    font-size: var(--text-xs);
    color: var(--ink-faint);
    line-height: 1.7;
    margin: 0;
  }
  .hero-hint a {
    color: var(--ink-muted);
  }
  .hero-hint a:hover {
    color: var(--ink);
  }
  @media (max-width: 860px) {
    .hero {
      grid-template-columns: 1fr;
      height: auto;
      min-height: 0;
      padding: var(--space-8) var(--space-6) var(--space-10);
      gap: var(--space-6);
    }
    .hero-text {
      max-width: none;
      justify-self: start;
      align-self: start;
    }
    .hero-globe {
      height: auto;
    }
  }

  .band {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6);
    border-top: 1px solid var(--hairline);
  }
  .band-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }
  .band-head h2 {
    font-family: var(--font-reading);
    font-size: var(--text-2xl);
    margin: 0;
  }
  .band-head a {
    font-family: var(--font-instrument);
    font-size: var(--text-sm);
    color: var(--ink-muted);
    text-decoration: none;
    white-space: nowrap;
  }
  .band-head a:hover {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--hairline);
    text-underline-offset: 3px;
  }
  .band-lede {
    margin: 0;
    color: var(--ink-muted);
    max-width: var(--measure);
  }
  .bloc-counts {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-8);
  }
  .bloc-counts li {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    font-family: var(--font-instrument);
    color: var(--ink);
  }
  .bloc-counts .sw {
    width: 0.7em;
    height: 0.7em;
    border-radius: 50%;
    background: var(--c);
    align-self: center;
  }
  .bloc-counts .n {
    color: var(--ink-faint);
    font-size: var(--text-sm);
  }
  .latest {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid var(--hairline);
    padding-bottom: var(--space-3);
  }
  .latest:hover .latest-title {
    text-decoration: underline;
    text-decoration-color: var(--hairline);
    text-underline-offset: 3px;
  }
  .latest-title {
    font-family: var(--font-reading);
    font-size: var(--text-lg);
  }
  .latest-date {
    color: var(--ink-muted);
    font-size: var(--text-sm);
  }
  .briefing {
    font-family: var(--font-instrument);
    font-size: var(--text-sm);
    color: var(--ink-muted);
    text-decoration: none;
  }
  .briefing:hover {
    color: var(--ink);
  }
</style>
