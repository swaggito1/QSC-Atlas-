---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((p) => ({ params: { slug: p.data.slug }, props: { post: p.data } }));
}

const { post } = Astro.props;
---

<Base title={post.title} description={post.excerpt ?? undefined}>
  <article class="container post">
    <p class="back"><a href="/analysis">&larr; Analysis</a></p>
    <h1>{post.title}</h1>
    <p class="meta mono">{[post.published, post.author].filter(Boolean).join(' · ')}</p>
    {post.excerpt && <p class="prose lede">{post.excerpt}</p>}
    <p class="note">The full text follows shortly.</p>
  </article>
</Base>

<style>
  .post {
    max-width: var(--measure);
  }
  .back {
    font-size: 0.85rem;
    margin-bottom: var(--space-6);
  }
  .back a {
    color: var(--ink-muted);
    text-decoration: none;
  }
  .post h1 {
    font-family: var(--font-reading);
    font-size: 2rem;
  }
  .meta {
    font-size: 0.8rem;
    color: var(--ink-muted);
    margin-bottom: var(--space-6);
  }
  .lede {
    font-size: 1.15rem;
  }
  .note {
    margin-top: var(--space-8);
    color: var(--ink-muted);
    font-style: italic;
  }
</style>
