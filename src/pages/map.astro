---
import { createRequire } from 'node:module';
import Base from '../layouts/Base.astro';
import WorldMap from '../components/WorldMap';
import { getCollection } from 'astro:content';

// The flat map (planisphere), reached from the globe. Same data, keyed by ccn3.
const require = createRequire(import.meta.url);
let worldCountries: any = require('world-countries');
if (!Array.isArray(worldCountries)) worldCountries = worldCountries.default ?? [];
const CCN3: Record<string, string> = Object.fromEntries(worldCountries.map((c: any) => [c.cca3, c.ccn3]));

const countries = await getCollection('countries');
const mapProcess: Record<string, any> = {};
for (const c of countries) {
  const d = c.data;
  if (!d.coordinationPosture) continue;
  const ccn3 = CCN3[d.iso3];
  if (ccn3) mapProcess[String(Number(ccn3))] = { iso3: d.iso3, name: d.country, posture: d.coordinationPosture, role: d.standardsRole ?? null, confidence: d.confidence ?? null };
}
---

<Base title="World map">
  <div class="map-page">
    <p class="back"><a href="/">&larr; Back to the globe</a></p>
    <WorldMap client:load mapProcess={mapProcess} />
    <p class="map-note">Click a country to open its profile.</p>
  </div>
</Base>

<style>
  .map-page {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: var(--space-6) var(--space-6) var(--space-12);
  }
  .back {
    font-size: var(--text-sm);
    margin: 0 0 var(--space-5);
  }
  .back a {
    color: var(--ink-muted);
    text-decoration: none;
  }
  .back a:hover {
    color: var(--ink);
  }
  .map-note {
    margin: var(--space-4) 0 0;
    font-size: var(--text-xs);
    color: var(--ink-faint);
    font-family: var(--font-mono);
  }
</style>
