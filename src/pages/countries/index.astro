---
import Base from '../../layouts/Base.astro';
import RoleBadge from '../../components/RoleBadge.astro';
import { getCollection } from 'astro:content';
import { POSTURE_ORDER, POSTURE_META } from '../../lib/process';

// A census, not a card wall. Countries are grouped by coordination bloc, in the same
// order as the map legend, so the single most important fact (which bloc a country
// belongs to) organises the page. Within a bloc, a tight ruled list, target years in
// a clean numeric column.
const all = await getCollection('countries');
const byPosture = (p: string) =>
  all
    .filter((c) => c.data.coordinationPosture === p)
    .sort((a, b) => a.data.country.localeCompare(b.data.country));
const groups = POSTURE_ORDER.map((p) => ({ meta: POSTURE_META[p], rows: byPosture(p) })).filter((g) => g.rows.length);
const classified = all.filter((c) => c.data.coordinationPosture).length;
const unclassified = all.length - classified;
---

<Base title="Countries">
  <div class="container">
    <h1>Countries</h1>
    <p class="status mono">
      {all.length} profiles · {classified} placed in a coordination bloc · the map shows the same set
    </p>
    <input
      type="search"
      id="country-search"
      class="country-search"
      placeholder="Find a country"
      aria-label="Find a country"
      autocomplete="off"
    />
    <p class="no-match mono" id="no-match" hidden>No country matches that name.</p>

    {
      groups.map((g) => (
        <section class="bloc">
          <header class="bloc-head" style={`--bloc:${g.meta.color}`}>
            <span class="bloc-sw" aria-hidden="true" />
            <h2>{g.meta.label}</h2>
            <span class="bloc-count mono">{g.rows.length}</span>
          </header>
          <ul class="census">
            {g.rows.map((c) => (
              <li class="row" style={`--bloc:${g.meta.color}`}>
                <a class="row-name" href={`/countries/${c.data.iso3.toLowerCase()}`}>
                  {c.data.country}
                </a>
                <span class="row-role">
                  {c.data.standardsRole && <RoleBadge value={c.data.standardsRole} short />}
                </span>
                <span class="row-year mono">{c.data.targetCompletion ?? ''}</span>
              </li>
            ))}
          </ul>
        </section>
      ))
    }

    {
      unclassified > 0 && (
        <p class="tail mono">
          {unclassified} further countries are on record with no coordination posture yet.
        </p>
      )
    }
  </div>
  <script is:inline>
    (() => {
      const input = document.getElementById('country-search');
      if (!input) return;
      const rows = Array.from(document.querySelectorAll('.row'));
      const groups = Array.from(document.querySelectorAll('.bloc'));
      const tail = document.querySelector('.tail');
      const noMatch = document.getElementById('no-match');
      const norm = (s) => s.toLowerCase().normalize('NFD').replace(/\p{Diacritic}/gu, '');
      input.addEventListener('input', () => {
        const q = norm(input.value.trim());
        let shown = 0;
        for (const r of rows) {
          const name = norm(r.querySelector('.row-name')?.textContent || '');
          const match = !q || name.includes(q);
          r.style.display = match ? '' : 'none';
          if (match) shown++;
        }
        for (const g of groups) {
          const visible = Array.from(g.querySelectorAll('.row')).some((r) => r.style.display !== 'none');
          g.style.display = visible ? '' : 'none';
        }
        if (tail) tail.style.display = q ? 'none' : '';
        if (noMatch) noMatch.hidden = !(q && shown === 0);
      });
    })();
  </script>
</Base>

<style>
  .status {
    color: var(--ink-faint);
    font-size: var(--text-xs);
    margin: 0 0 var(--space-4);
  }
  .country-search {
    display: block;
    width: 100%;
    max-width: 22rem;
    font-family: var(--font-instrument);
    font-size: var(--text-base);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--ink);
    margin: 0 0 var(--space-10);
  }
  .country-search::placeholder {
    color: var(--ink-faint);
  }
  .no-match {
    color: var(--ink-muted);
    font-size: var(--text-sm);
    margin: 0 0 var(--space-8);
  }
  .bloc {
    margin-bottom: var(--space-12);
  }
  .bloc-head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--ink);
    margin-bottom: var(--space-1);
  }
  .bloc-sw {
    width: 0.7em;
    height: 0.7em;
    border-radius: 50%;
    background: var(--bloc);
    flex: none;
  }
  .bloc-head h2 {
    font-family: var(--font-label);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    font-weight: 400;
    margin: 0;
  }
  .bloc-count {
    margin-left: auto;
    color: var(--ink-faint);
    font-size: var(--text-xs);
  }
  .census {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .row {
    display: grid;
    grid-template-columns: 1fr auto 4em;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-2) var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--hairline);
    position: relative;
    transition: background var(--dur-fast) var(--ease);
  }
  .row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--bloc);
    opacity: 0.5;
    transition: width var(--dur-fast) var(--ease), opacity var(--dur-fast) var(--ease);
  }
  .row:hover {
    background: var(--wash);
  }
  .row:hover::before {
    width: 3px;
    opacity: 1;
  }
  .row-name {
    font-family: var(--font-reading);
    font-size: var(--text-lg);
    color: var(--ink);
    text-decoration: none;
  }
  /* Stretch the link's tap area over the whole row, so the target is the full ~53px row
     rather than the 29px text line. The other cells are plain text, so nothing competes. */
  .row-name::after {
    content: '';
    position: absolute;
    inset: 0;
  }
  .row-name:hover {
    text-decoration: underline;
    text-decoration-color: var(--hairline);
    text-underline-offset: 3px;
  }
  .row-year {
    color: var(--ink-muted);
    font-size: var(--text-sm);
    text-align: right;
  }
  .tail {
    color: var(--ink-faint);
    font-size: var(--text-xs);
    border-top: 1px solid var(--hairline);
    padding-top: var(--space-4);
  }
</style>
