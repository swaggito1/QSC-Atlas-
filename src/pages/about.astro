---
import Base from '../layouts/Base.astro';

// Organisations that took part in the two CEPS Task Forces (2023 and 2025), combined and
// de-duplicated. Logos load from Clearbit with a favicon fallback, so a mark always renders.
const partners = [
  { n: 'Deloitte', d: 'deloitte.com' },
  { n: 'EY', d: 'ey.com' },
  { n: 'KPMG', d: 'kpmg.com' },
  { n: 'Microsoft', d: 'microsoft.com' },
  { n: 'IBM', d: 'ibm.com' },
  { n: 'Intel', d: 'intel.com' },
  { n: 'Ericsson', d: 'ericsson.com' },
  { n: 'Qualcomm', d: 'qualcomm.com' },
  { n: 'Quantinuum', d: 'quantinuum.com' },
  { n: 'Thales', d: 'thalesgroup.com' },
  { n: 'Leonardo', d: 'leonardo.com' },
  { n: 'Unisys', d: 'unisys.com' },
  { n: 'Brave', d: 'brave.com' },
  { n: 'Santander', d: 'santander.com' },
  { n: 'Sparkle', d: 'tisparkle.com' },
  { n: 'Algorithmiq', d: 'algorithmiq.fi' },
  { n: 'Inveriant', d: 'inveriant.com' },
  { n: 'Intellera Consulting', d: 'intelleraconsulting.com' },
  { n: 'Raiffeisen Bank International', d: 'rbinternational.com' },
  { n: 'Zurich Insurance', d: 'zurich.com' },
  { n: 'Cassa Depositi e Prestiti', d: 'cdp.it' },
  { n: 'Quantum Business Network', d: 'qbn.world' },
  { n: 'FS-ISAC', d: 'fsisac.com' },
  { n: 'Bank for International Settlements', d: 'bis.org' },
  { n: 'European Central Bank', d: 'ecb.europa.eu' },
  { n: "Banca d'Italia", d: 'bancaditalia.it' },
  { n: 'Inter-American Development Bank', d: 'iadb.org' },
  { n: 'Financial Conduct Authority', d: 'fca.org.uk' },
  { n: 'European Parliament', d: 'europarl.europa.eu' },
  { n: 'European Commission', d: 'commission.europa.eu' },
  { n: 'ENISA', d: 'enisa.europa.eu' },
  { n: 'European Defence Agency', d: 'eda.europa.eu' },
  { n: 'European Space Agency', d: 'esa.int' },
  { n: 'ETSI', d: 'etsi.org' },
  { n: 'European Investment Bank', d: 'eib.org' },
  { n: 'EU Quantum Flagship', d: 'qt.eu' },
  { n: 'BSI', d: 'bsi.bund.de' },
  { n: 'ANSSI', d: 'cyber.gouv.fr' },
  { n: 'NIST', d: 'nist.gov' },
  { n: 'NATO', d: 'nato.int' },
  { n: 'TNO', d: 'tno.nl' },
  { n: 'ICANN', d: 'icann.org' },
  { n: 'Internet Society', d: 'internetsociety.org' },
  { n: 'Hybrid CoE', d: 'hybridcoe.fi' },
  { n: 'KU Leuven', d: 'kuleuven.be' },
  { n: 'Alan Turing Institute', d: 'turing.ac.uk' },
  { n: 'University of Helsinki', d: 'helsinki.fi' },
  { n: 'Istituto Italiano di Tecnologia', d: 'iit.it' },
  { n: 'University of Amsterdam', d: 'uva.nl' },
  { n: 'Utrecht University', d: 'uu.nl' },
  { n: 'Stanford University', d: 'stanford.edu' },
  { n: 'TU Delft', d: 'tudelft.nl' },
  { n: 'University of Waterloo', d: 'uwaterloo.ca' },
  { n: 'Loughborough University', d: 'lboro.ac.uk' },
  { n: 'École Polytechnique', d: 'polytechnique.edu' },
  { n: 'University of Málaga', d: 'uma.es' },
  { n: 'University of Primorska', d: 'upr.si' },
  { n: 'University of Salento', d: 'unisalento.it' },
  { n: 'German Marshall Fund', d: 'gmfus.org' },
  { n: 'I-Com', d: 'i-com.it' },
  { n: 'GESDA', d: 'gesda.global' },
];
const ROWS = 5;
const rows: { n: string; d: string }[][] = Array.from({ length: ROWS }, () => []);
partners.forEach((p, i) => rows[i % ROWS].push(p));
---

<Base title="About">
  <div class="container about">
    <h1>About the QSC Atlas</h1>
    <p class="prose credibility">
      An independent, evidence-based reference on how governments are migrating to quantum-safe
      cryptography, built only from official institutional sources and maintained alongside advisory
      work on the transition.
    </p>
    <p class="prose lead">
      The Atlas is maintained within the Cybersecurity@CEPS Initiative at the Centre for European
      Policy Studies. How it classifies countries, and the sources behind every profile, are set out
      in the <a href="/methodology">methodology</a>.
    </p>

    <h2>Who is behind it</h2>
    <ul class="team">
      <li>
        <a class="person" href="https://www.ceps.eu/ceps-staff/swann-ashworth/" target="_blank" rel="noopener">
          <img
            class="person-photo"
            src="/team/swann-ashworth.jpeg"
            alt="Swann Ashworth"
            width="465"
            height="659"
            loading="lazy"
          />
          <span class="person-name">Swann Ashworth</span>
          <span class="person-title">Associate Research Assistant, GRID Unit</span>
        </a>
      </li>
      <li>
        <a class="person" href="https://www.ceps.eu/ceps-staff/lorenzo-pupillo/" target="_blank" rel="noopener">
          <img
            class="person-photo"
            src="/team/lorenzo-pupillo.jpeg"
            alt="Lorenzo Pupillo"
            width="179"
            height="270"
            loading="lazy"
          />
          <span class="person-name">Lorenzo Pupillo</span>
          <span class="person-title">Head of the Cybersecurity@CEPS Initiative</span>
        </a>
      </li>
    </ul>

    <h2>Our Task Forces</h2>
    <ul class="tasks">
      <li>
        <h3>
          <a href="https://www.ceps.eu/ceps-publications/quantum-technologies-and-cybersecurity/" target="_blank" rel="noopener">
            Quantum Technologies and Cybersecurity (2023) &rarr;
          </a>
        </h3>
        <p class="prose">
          Launched in March 2023, this CEPS Task Force examined the technical, ethical, market and
          governance challenges at the intersection of quantum technologies and cybersecurity. It set
          out policy recommendations for EU institutions, Member States, industry and the research
          community on developing and deploying quantum-safe technologies.
        </p>
      </li>
      <li>
        <h3>
          <a href="https://www.ceps.eu/ceps-publications/strengthening-the-eu-transition-to-a-quantum-safe-world/" target="_blank" rel="noopener">
            Strengthening the EU Transition to a Quantum-Safe World (2025) &rarr;
          </a>
        </h3>
        <p class="prose">
          Launched in April 2025 as a multi-stakeholder platform, this CEPS Task Force addressed the
          technical, market, governance and policy challenges of Europe's move to post-quantum
          cryptography. It produced practical guidelines and recommendations to accelerate a
          coordinated, secure transition across the public and private sectors.
        </p>
      </li>
    </ul>

    <section class="partners">
      <h3 class="partners-head">Task force participants</h3>
      <p class="prose credibility">The organisations that took part in our two Task Forces, combined.</p>
      <div class="marquees">
        {
          rows.map((row, ri) => (
            <div class={`marquee ${ri % 2 ? 'is-rev' : ''}`}>
              <div class="track" style={`--dur:${38 + ri * 5}s`}>
                {row.map((p) => (
                  <a class="logo" href={`https://${p.d}`} target="_blank" rel="noopener" aria-label={p.n} title={p.n}>
                    <img
                      src={`https://logo.clearbit.com/${p.d}`}
                      alt=""
                      loading="lazy"
                      onerror={`this.onerror=null;this.src='https://www.google.com/s2/favicons?domain=${p.d}&sz=128'`}
                    />
                  </a>
                ))}
                {row.map((p) => (
                  <a class="logo" href={`https://${p.d}`} target="_blank" rel="noopener" aria-hidden="true" tabindex="-1">
                    <img
                      src={`https://logo.clearbit.com/${p.d}`}
                      alt=""
                      loading="lazy"
                      onerror={`this.onerror=null;this.src='https://www.google.com/s2/favicons?domain=${p.d}&sz=128'`}
                    />
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <h2 id="briefing">Request a briefing</h2>
    <p class="prose">
      The Atlas is maintained alongside advisory work on the quantum-safe transition. For a briefing
      tailored to your organisation or sector, get in touch.
    </p>
    <p>
      <a class="briefing-link" href="mailto:swann.ashworth@ceps.eu?subject=QSC%20Atlas%20briefing">
        Request a briefing
      </a>
    </p>
  </div>
</Base>

<style>
  .about h1 {
    font-family: var(--font-reading);
  }
  .about h2 {
    font-family: var(--font-reading);
    margin-top: var(--space-16);
  }
  .lead {
    font-size: var(--text-lg);
  }
  .lead a,
  .tasks h3 a {
    color: var(--ink);
    text-underline-offset: 3px;
    text-decoration-color: var(--hairline);
  }
  .lead a:hover,
  .tasks h3 a:hover {
    text-decoration-color: var(--ink);
  }
  .credibility {
    color: var(--ink-muted);
    font-size: var(--text-base);
    margin-top: 0;
  }

  /* Team: clickable portraits that open the CEPS profile. */
  .team {
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
  }
  .person {
    display: grid;
    justify-items: start;
    gap: var(--space-1);
    text-decoration: none;
    color: var(--ink);
    max-width: 12rem;
  }
  .person-photo {
    width: 8.5rem;
    height: 10.6rem;
    object-fit: cover;
    filter: grayscale(1) contrast(1.02);
    border: 1px solid var(--hairline);
    margin-bottom: var(--space-2);
    transition: filter var(--dur, 0.2s) var(--ease, ease);
  }
  .person:hover .person-photo,
  .person:focus-visible .person-photo {
    filter: grayscale(0);
  }
  .person-name {
    font-family: var(--font-instrument);
    font-weight: 600;
  }
  .person:hover .person-name {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--ink);
  }
  .person-title {
    font-size: var(--text-sm);
    color: var(--ink-muted);
  }

  /* Task forces: title link plus a two-sentence note. */
  .tasks {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-6);
    max-width: var(--measure);
  }
  .tasks h3 {
    font-family: var(--font-instrument);
    font-size: var(--text-base);
    margin: 0 0 var(--space-2);
  }
  .tasks .prose {
    color: var(--ink-muted);
    margin: 0;
  }

  .briefing-link {
    display: inline-block;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    padding: var(--space-2) var(--space-4);
    text-decoration: none;
    font-family: var(--font-instrument);
  }
  .briefing-link:hover {
    background: var(--ink);
    color: var(--paper);
  }

  /* Participant logo banners: five rows, alternating scroll direction. */
  .partners {
    margin-top: var(--space-16);
  }
  .partners-head {
    font-family: var(--font-instrument);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-muted);
    margin: 0 0 var(--space-2);
  }
  .marquees {
    margin-top: var(--space-6);
    display: grid;
    gap: var(--space-4);
  }
  .marquee {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
  }
  .track {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    width: max-content;
    animation: marq var(--dur, 40s) linear infinite;
  }
  .marquee.is-rev .track {
    animation-direction: reverse;
  }
  .marquee:hover .track {
    animation-play-state: paused;
  }
  @keyframes marq {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  .logo {
    flex: none;
    display: inline-flex;
    align-items: center;
  }
  .logo img {
    height: 26px;
    width: auto;
    max-width: 120px;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.6;
    transition: opacity 0.2s ease, filter 0.2s ease;
  }
  .logo:hover img {
    filter: grayscale(0);
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .track {
      animation: none;
      flex-wrap: wrap;
      width: auto;
    }
    .marquee {
      -webkit-mask-image: none;
      mask-image: none;
    }
  }
</style>
