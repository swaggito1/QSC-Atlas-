---
import Base from '../layouts/Base.astro';
import { POSTURE_ORDER, POSTURE_META, ROLE_ORDER, ROLE_META } from '../lib/process';

const postureDef: Record<string, string> = {
  'NIST-bloc': 'Works to the standards and cadence the United States sets through NIST. The largest group by far.',
  EU: 'Migrates in step with the EU coordinated roadmap, on its 2030 and 2035 milestones, over the NIST algorithms underneath.',
  'sovereign-bloc': 'Builds and mandates its own national algorithms, independent of NIST. The only real fork in the baseline.',
  'engaged-unaligned': 'Active on the transition, but committed to no bloc, standard, or timeline.',
};
const roleDef: Record<string, string> = {
  setter: 'Writes the standards others adopt. Today there is one: the United States.',
  contextualiser: 'Adopts the baseline but adds national requirements, such as mandatory hybrid deployment or certification.',
  taker: 'Adopts the baseline broadly as published, without a substantial national overlay.',
  'sovereign-developer': 'Designs and standardises its own post-quantum algorithms.',
};
---

<Base title="About">
  <div class="container about">
    <h1>About the QSC Atlas</h1>
    <p class="prose lead">
      The QSC Atlas shows, country by country, how governments are migrating to quantum-safe
      cryptography: the instruments that govern the move, which post-quantum standards a country
      adopts, the bloc it coordinates with, and where one exists, its timeline. It is built only
      from institutional sources, government bodies, national agencies and standards organisations,
      and every profile links to the documents it rests on. It is rebuilt as new documents appear.
    </p>

    <h2 id="classification">How the Atlas classifies countries</h2>
    <p class="prose">
      Every country is described on two dimensions, because two different things are easy to
      confuse. An EU member coordinates through the European roadmap, yet the algorithms it deploys
      are the American NIST standards, because there is no European alternative. A single label would
      conflate the two, so the Atlas records both: the map colour shows which collective transition a
      country coordinates with; a badge on its profile shows whose algorithms it actually runs.
    </p>

    <h3>Coordination posture, the map colour</h3>
    <dl class="ref">
      {
        POSTURE_ORDER.map((k) => (
          <div class="ref-row" style={`--c:${POSTURE_META[k].color}`}>
            <span class="ref-sw" aria-hidden="true" />
            <dt>{POSTURE_META[k].label}</dt>
            <dd class="prose">{postureDef[k]}</dd>
          </div>
        ))
      }
    </dl>

    <h3>Standards role, the profile badge</h3>
    <dl class="ref">
      {
        ROLE_ORDER.map((k) => (
          <div class="ref-row" style={`--c:${ROLE_META[k].color}`}>
            <span class="ref-sw" aria-hidden="true" />
            <dt>{ROLE_META[k].label}</dt>
            <dd class="prose">{roleDef[k]}</dd>
          </div>
        ))
      }
    </dl>

    <p class="prose ref-note">
      Confidence is shown with every classification and sets how strongly a country is coloured, so a
      low-confidence call reads softer. Faint grey is no data, which is not the same as engaged but
      unaligned: one has nothing on record, the other is active but undecided.
    </p>

    <h2 id="briefing">Request a briefing</h2>
    <p class="prose">
      The Atlas is maintained alongside advisory work on the quantum-safe transition. For a briefing
      tailored to your organisation or sector, get in touch.
    </p>
    <p>
      <a class="briefing-link" href="mailto:hello@example.com?subject=QSC%20Atlas%20briefing">
        Request a briefing
      </a>
    </p>
  </div>
</Base>

<style>
  .about h1 {
    font-family: var(--font-reading);
  }
  .about h2 {
    font-family: var(--font-reading);
    margin-top: var(--space-16);
  }
  .about h3 {
    font-family: var(--font-instrument);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-muted);
    margin: var(--space-10) 0 var(--space-4);
  }
  .lead {
    font-size: var(--text-lg);
  }
  .ref {
    margin: 0;
    display: grid;
    gap: 0;
  }
  .ref-row {
    display: grid;
    grid-template-columns: 1em minmax(9em, 14em) 1fr;
    gap: var(--space-3) var(--space-5);
    align-items: baseline;
    padding: var(--space-4) 0;
    border-top: 1px solid var(--hairline);
  }
  .ref-row:last-child {
    border-bottom: 1px solid var(--hairline);
  }
  .ref-sw {
    width: 0.8em;
    height: 0.8em;
    border-radius: 50%;
    background: var(--c);
    align-self: center;
  }
  .ref dt {
    font-family: var(--font-instrument);
    font-weight: 600;
    color: var(--ink);
  }
  .ref dd {
    margin: 0;
    font-size: var(--text-base);
    color: var(--ink-muted);
  }
  .ref-note {
    color: var(--ink-muted);
    font-size: var(--text-sm);
    margin-top: var(--space-6);
  }
  .briefing-link {
    display: inline-block;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    padding: var(--space-2) var(--space-4);
    text-decoration: none;
    font-family: var(--font-instrument);
  }
  .briefing-link:hover {
    background: var(--ink);
    color: var(--paper);
  }
  @media (max-width: 560px) {
    .ref-row {
      grid-template-columns: 1em 1fr;
    }
    .ref dd {
      grid-column: 2;
    }
  }
</style>
