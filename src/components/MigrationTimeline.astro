---
// The migration timeline: a fixed axis 2025 to 2036 so countries are comparable.
// The axis carries the dots and their years; every milestone is then spelled out
// in a readable list beneath it. Only the final marker takes the process colour.
// Ported from the QSC Atlas design system. Empty state is a calm statement.
import { parseTimeline } from '../lib/parse';
import { postureMeta } from '../lib/process';

interface Props {
  raw: string | null | undefined;
  process?: string | null;
  target?: string | null;
}
const { raw, process = null, target = null } = Astro.props;

const AXIS_START = 2025;
const AXIS_END = 2036;
const pct = (year: number) => Math.max(0, Math.min(100, ((year - AXIS_START) / (AXIS_END - AXIS_START)) * 100));

const items = parseTimeline(raw);
const numeric = items.filter((m) => typeof m.year === 'number') as { year: number; label: string }[];
const accent = postureMeta(process)?.color ?? 'var(--ink)';
const today = new Date().getFullYear();
const phased = target === 'Phased (no fixed end)' || items.some((m) => typeof m.year === 'string');
const anchorFor = (p: number) => (p > 88 ? 'translateX(-100%)' : p < 12 ? 'translateX(0)' : 'translateX(-50%)');
---

{
  items.length ? (
    <figure class="tl" style={`--accent:${accent}`}>
      <div class="track">
        <div class="axis" />
        {today >= AXIS_START && today <= AXIS_END && (
          <div class="today" style={`left:${pct(today)}%`}>
            <span class="today-label mono">today</span>
          </div>
        )}
        {numeric.map((m, i) => (
          <div class="mark" style={`left:${pct(m.year)}%`}>
            <span class="year mono" style={`transform:${anchorFor(pct(m.year))}`}>{m.year}</span>
            <span class:list={['dot', { final: i === numeric.length - 1 }]} />
          </div>
        ))}
        {phased && <span class="phased mono">phased &rarr;</span>}
      </div>
      <div class="ends mono">
        <span>{AXIS_START}</span>
        <span>{AXIS_END}</span>
      </div>
      <ol class="rows">
        {numeric.map((m, i) => (
          <li>
            <span class="row-year">
              <span class:list={['rdot', { final: i === numeric.length - 1 }]} />
              <span class="mono">{m.year}</span>
            </span>
            <span class="row-label">{m.label}</span>
          </li>
        ))}
      </ol>
    </figure>
  ) : (
    <p class="empty">No published migration timeline.</p>
  )
}

<style>
  .tl { margin: var(--space-5) 0 0; }
  .track { position: relative; height: 40px; margin-top: 1.1em; }
  .axis { position: absolute; left: 0; right: 0; bottom: 0; height: 2px; background: var(--ink); }
  .today { position: absolute; top: -2px; bottom: 0; transform: translateX(-50%); border-left: 1px dashed var(--ink-muted); }
  .today-label { position: absolute; top: -1.25em; left: 50%; transform: translateX(-50%); font-size: var(--text-2xs); color: var(--ink-muted); }
  .mark { position: absolute; bottom: 0; }
  .year { position: absolute; bottom: 12px; left: 0; font-size: var(--text-2xs); color: var(--ink); white-space: nowrap; }
  .dot { position: absolute; bottom: -3px; left: 0; transform: translateX(-50%); width: 7px; height: 7px; border-radius: 50%; background: var(--ink); }
  .dot.final { bottom: -5px; width: 11px; height: 11px; background: var(--accent); border: 2px solid var(--surface); }
  .phased { position: absolute; right: 0; bottom: 12px; font-size: var(--text-2xs); color: var(--ink-muted); }
  .ends { display: flex; justify-content: space-between; font-size: var(--text-2xs); color: var(--ink-faint); margin-top: var(--space-1); }
  .rows { list-style: none; margin: var(--space-5) 0 0; padding: 0; display: grid; gap: var(--space-3); }
  .rows li { display: grid; grid-template-columns: auto 1fr; gap: var(--space-3); align-items: baseline; }
  .row-year { display: inline-flex; align-items: center; gap: var(--space-2); font-size: var(--text-xs); color: var(--ink); }
  .rdot { width: 7px; height: 7px; border-radius: 50%; background: var(--ink); flex: none; }
  .rdot.final { background: var(--accent); }
  .row-label { font-size: var(--text-sm); color: var(--ink-muted); line-height: 1.45; }
  .empty { color: var(--ink-muted); font-style: italic; border-top: 2px solid var(--hairline); padding-top: var(--space-2); margin: var(--space-4) 0; }
</style>
