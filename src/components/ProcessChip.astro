---
// A country's coordination posture: a small coloured dot and its plain label. No box,
// no border. Colour plus the word carry it. One of the few places colour echoes the map.
import { postureMeta } from '../lib/process';

interface Props {
  value: string | null | undefined;
}
const { value } = Astro.props;
const meta = postureMeta(value);
---

{
  meta ? (
    <span class="process-chip" style={`--chip:${meta.color}`}>
      <span class="dot" aria-hidden="true" />
      {meta.short}
    </span>
  ) : (
    <span class="process-chip process-chip--none">Not classified</span>
  )
}

<style>
  .process-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-instrument);
    font-size: 0.92rem;
    color: var(--ink);
    white-space: nowrap;
  }
  .dot {
    width: 0.6em;
    height: 0.6em;
    border-radius: 50%;
    background: var(--chip);
    flex: none;
  }
  .process-chip--none {
    color: var(--ink-muted);
  }
</style>
