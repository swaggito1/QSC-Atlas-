---
// The map legend. Colour shows coordination posture (the bloc a country migrates
// with); a second key lists standards role, shown as a badge on profiles and used
// when the map is recoloured by role. Colour is never the only carrier of meaning.
import { POSTURE_ORDER, POSTURE_META, ROLE_ORDER, ROLE_META } from '../lib/process';
---

<ul class="legend" aria-label="Map legend: coordination posture">
  {
    POSTURE_ORDER.map((key) => (
      <li>
        <span class="swatch" style={`background:${POSTURE_META[key].color}`} aria-hidden="true" />
        {POSTURE_META[key].label}
      </li>
    ))
  }
  <li>
    <span class="swatch swatch--none" aria-hidden="true" />
    No data
  </li>
</ul>

<p class="role-title">Standards role</p>
<ul class="legend" aria-label="Map legend: standards role">
  {
    ROLE_ORDER.map((key) => (
      <li>
        <span class="swatch" style={`background:${ROLE_META[key].color}`} aria-hidden="true" />
        {ROLE_META[key].label}
      </li>
    ))
  }
</ul>

<style>
  .legend {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-2);
    font-size: 0.9rem;
    font-family: var(--font-instrument);
  }
  .legend li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .swatch {
    width: 0.95em;
    height: 0.95em;
    border-radius: 2px;
    display: inline-block;
    border: 1px solid rgba(0, 0, 0, 0.12);
  }
  .swatch--none {
    background: var(--process-none);
  }
  .role-title {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-faint);
    font-weight: 600;
    margin: var(--space-4) 0 var(--space-2);
  }
</style>
