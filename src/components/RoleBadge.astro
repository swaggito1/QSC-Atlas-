---
// The standards-role annotation: whose algorithms a country runs. Rendered as small
// uppercase muted text, not a second boxed chip competing with the posture. Renders
// nothing when no role is recorded.
import { roleMeta } from '../lib/process';

interface Props {
  value: string | null | undefined;
}
const { value } = Astro.props;
const meta = roleMeta(value);
---

{meta && <span class="role-badge">{meta.label}</span>}

<style>
  .role-badge {
    font-family: var(--font-instrument);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-muted);
    white-space: nowrap;
  }
</style>
