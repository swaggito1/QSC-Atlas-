---
// The two-axis matrix (brief 3.2): coordination posture (columns) by standards role (rows),
// with the live country count in each cell. An accessible labelled grid, coloured only by
// bloc, so it reads without relying on hue. Self-contained: it reads the collection itself,
// so the home scene and the methodology page can both just drop it in.
import { getCollection } from 'astro:content';
import { POSTURE_ORDER, POSTURE_META, ROLE_ORDER, ROLE_META } from '../lib/process';

const countries = await getCollection('countries');
const classified = countries.filter((c) => c.data.coordinationPosture).length;
const cell = (p: string, r: string) =>
  countries.filter((c) => c.data.coordinationPosture === p && c.data.standardsRole === r).length;
---

<figure class="matrix-fig">
  <table class="matrix">
    <caption class="sr-only">Countries by coordination posture (columns) and standards role (rows).</caption>
    <thead>
      <tr>
        <td></td>
        {
          POSTURE_ORDER.map((p) => (
            <th scope="col">
              <span class="sw" style={`--c:${POSTURE_META[p].color}`} aria-hidden="true" />
              {POSTURE_META[p].label}
            </th>
          ))
        }
      </tr>
    </thead>
    <tbody>
      {
        ROLE_ORDER.map((r) => (
          <tr>
            <th scope="row">{ROLE_META[r].short}</th>
            {POSTURE_ORDER.map((p) => <td class="mono">{cell(p, r) || ''}</td>)}
          </tr>
        ))
      }
    </tbody>
  </table>
  <figcaption>
    Live counts across {classified} classified countries. Colour shows the bloc; every cell is labelled.
  </figcaption>
</figure>

<style>
  .matrix-fig {
    margin: var(--space-6) 0;
  }
  .matrix {
    border-collapse: collapse;
    font-size: var(--text-sm);
  }
  .matrix th {
    font-weight: 400;
    text-align: left;
    color: var(--ink-muted);
    padding: var(--space-2) var(--space-3);
    vertical-align: bottom;
  }
  .matrix thead th {
    font-family: var(--font-label);
    font-size: var(--text-2xs);
    line-height: 1.2;
  }
  .matrix tbody th {
    font-family: var(--font-label);
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    white-space: nowrap;
  }
  .matrix .sw {
    display: inline-block;
    width: 0.6em;
    height: 0.6em;
    border-radius: 50%;
    background: var(--c);
    margin-right: 0.4em;
  }
  .matrix td {
    text-align: center;
    padding: var(--space-2) var(--space-3);
    border-top: 1px solid var(--hairline);
    color: var(--ink);
    min-width: 3.2em;
  }
  .matrix-fig figcaption {
    margin-top: var(--space-2);
    font-size: var(--text-xs);
    color: var(--ink-faint);
    max-width: var(--measure);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
