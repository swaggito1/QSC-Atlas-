---
// The country profile: the heart of the site. Renders the sections in the brief's
// order with calm empty states, alongside a sticky "at a glance" rail that surfaces
// the load-bearing facts (legal status, target, document count, verification, date).
// Institution names link through to the Documents tool pre-filtered to that issuer.
import ProcessChip from './ProcessChip.astro';
import RoleBadge from './RoleBadge.astro';
import MigrationTimeline from './MigrationTimeline.astro';
import { parseNameRole, parseList, parseRegulation } from '../lib/parse';
import { legalStatusMeta, instrumentStatusMeta, deriveLegalStatus } from '../lib/regulation';
import CredibilityGauge from './CredibilityGauge';
import type { Evaluation } from '../lib/evaluation';

interface CountryData {
  country: string;
  iso3: string;
  summary?: string | null;
  govActors?: string | null;
  standardFamilies?: string | null;
  algorithms?: string | null;
  dominantProcess?: string | null;
  secondaryProcess?: string | null;
  coordinationPosture?: string | null;
  standardsRole?: string | null;
  mainRegulation?: string | null;
  legalStatus?: string | null;
  obligation?: string | null;
  confidence?: string | null;
  processParticipation?: string | null;
  hybridDeployment?: string | null;
  migrationTimeline?: string | null;
  targetCompletion?: string | null;
  verificationStatus?: string | null;
  lastUpdated?: string | null;
}
interface DocData {
  title: string;
  issuingOrg?: string | null;
  year?: number | null;
  tier?: string | null;
  url?: string | null;
}
interface Props {
  country: CountryData;
  documents?: DocData[];
  evaluation?: Evaluation | null;
  blocColor?: string | null;
}
const { country, documents = [], evaluation = null, blocColor = null } = Astro.props;

const families = parseList(country.standardFamilies);
const algorithms = parseList(country.algorithms);
const govActors = parseNameRole(country.govActors);
const participation = parseNameRole(country.processParticipation);
const regulations = parseRegulation(country.mainRegulation).map((r) => ({
  ...r,
  statusMeta: instrumentStatusMeta(r.status),
}));
const legal =
  legalStatusMeta(country.legalStatus) ??
  (regulations.length ? legalStatusMeta(deriveLegalStatus(regulations.map((r) => r.status))) : null);
const orgLink = (org: string) => `/documents?org=${encodeURIComponent(org)}`;
const verifiedLabel =
  country.verificationStatus === 'Verified'
    ? 'Verified against sources'
    : country.verificationStatus === 'Corrected'
      ? 'Corrected from sources'
      : null;
---

<article class="profile">
  <header class="profile-head">
    <h1>{country.country}</h1>
    <ProcessChip value={country.coordinationPosture} />
    {country.standardsRole && <RoleBadge value={country.standardsRole} />}
  </header>

  <div class="profile-body">
    <aside class="ataglance">
      <p class="ag-head">At a glance</p>
      <dl class="ag-list">
        {legal && (
          <div>
            <dt>Legal status</dt>
            <dd>{legal.label}</dd>
          </div>
        )}
        {country.targetCompletion && (
          <div>
            <dt>Target</dt>
            <dd class="mono">{country.targetCompletion}</dd>
          </div>
        )}
        <div>
          <dt>Documents</dt>
          <dd class="mono">{documents.length}</dd>
        </div>
        {verifiedLabel && (
          <div>
            <dt>Sources</dt>
            <dd class="verified">{verifiedLabel}</dd>
          </div>
        )}
        {country.lastUpdated && (
          <div>
            <dt>Updated</dt>
            <dd class="mono">{country.lastUpdated}</dd>
          </div>
        )}
      </dl>
    </aside>

    <div class="profile-main">
      {/* 1. Summary */}
      {
        country.summary ? (
          <p class="prose summary">{country.summary}</p>
        ) : (
          <p class="empty">No summary in the public record.</p>
        )
      }

      {/* Lead row: governance credibility (left) beside the regulatory basis (right).
          The analytical note is intentionally not rendered: it is an internal field,
          redacted from the public build (see docs/REGULATORY_LAYER_SPEC.md). */}
      <section class={`lead-row${evaluation ? ' has-gauge' : ''}`}>
        {
          evaluation && (
            <div class="lead-col gauge-col">
              <h2>Governance credibility</h2>
              <CredibilityGauge client:idle evaluation={evaluation} countryName={country.country} blocColor={blocColor ?? '#6b7280'} />
            </div>
          )
        }
        <div class="lead-col reg">
          <h2>Regulatory basis</h2>
          {
            regulations.length ? (
              <ul class="reg-list">
                {regulations.map((r) => (
                  <li>
                    <span class="reg-name">{r.instrument}</span>
                    <span class="reg-tags">
                      {r.level && <span class="reg-level">{r.level}</span>}
                      {r.statusMeta && (
                        <span class={`reg-status${r.statusMeta.binding ? ' is-binding' : ''}`}>
                          {r.statusMeta.label}
                        </span>
                      )}
                    </span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="empty">No governing instrument identified.</p>
            )
          }
          {legal && (
            <p class="legal-status">
              Legal status: <strong>{legal.label}</strong>
            </p>
          )}
          {country.obligation && <p class="obligation prose">{country.obligation}</p>}
        </div>
      </section>

      {/* 2. Standards and algorithms */}
      <section class="block">
        <h2>Standards and algorithms</h2>
        {
          families.length || algorithms.length ? (
            <dl class="data">
              {families.length > 0 && (
                <div>
                  <dt>Standard families</dt>
                  <dd>{families.join(', ')}</dd>
                </div>
              )}
              {algorithms.length > 0 && (
                <div>
                  <dt>Algorithms</dt>
                  <dd class="mono">{algorithms.join(', ')}</dd>
                </div>
              )}
            </dl>
          ) : (
            <p class="empty">No standards or algorithms specified.</p>
          )
        }
      </section>

      {/* 3. Hybrid stance */}
      <section class="block">
        <h2>Hybrid stance</h2>
        <p class="hybrid">{country.hybridDeployment?.trim() || 'None stated'}</p>
      </section>

      {/* 4. Migration timeline */}
      <section class="block">
        <h2>Migration timeline</h2>
        <MigrationTimeline
          raw={country.migrationTimeline}
          process={country.coordinationPosture}
          target={country.targetCompletion}
        />
        {country.targetCompletion && <p class="target mono">Target completion: {country.targetCompletion}</p>}
      </section>

      {/* 5. International standards processes */}
      {
        participation.length > 0 && (
          <section class="block">
            <h2>International standards processes</h2>
            <ul class="actors">
              {participation.map((p) => (
                <li>
                  <span class="actor-name">{p.name}</span>
                  {p.role && <span class="actor-role">{p.role}</span>}
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {/* 6. Standards-body actors */}
      <section class="block">
        <h2>Governmental and standards bodies</h2>
        {
          govActors.length ? (
            <ul class="actors">
              {govActors.map((a) => (
                <li>
                  <a class="actor-name" href={orgLink(a.name)}>
                    {a.name}
                  </a>
                  {a.role && <span class="actor-role">{a.role}</span>}
                </li>
              ))}
            </ul>
          ) : (
            <p class="empty">No institutional actors identified.</p>
          )
        }
      </section>

      {/* 7. Key documents */}
      <section class="block">
        <h2>Key institutional documents</h2>
        {
          documents.length ? (
            <ul class="docs">
              {documents.map((d) => (
                <li>
                  <a href={d.url ?? '#'} target={d.url ? '_blank' : undefined} rel={d.url ? 'noopener' : undefined}>
                    {d.title}
                  </a>
                  <span class="doc-meta mono">
                    {[d.issuingOrg, d.year, d.tier].filter(Boolean).join(' · ')}
                  </span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="empty">No documents indexed for this country.</p>
          )
        }
      </section>

      <p class="profile-cta">
        Advising on this transition, or your own sector's? <a href="/about#briefing">Request a briefing &rarr;</a>
      </p>
    </div>
  </div>
</article>

<style>
  .profile {
    max-width: none;
  }
  .profile-head {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }
  .profile-head h1 {
    font-family: var(--font-reading);
    font-size: 2rem;
    margin: 0;
  }
  .profile-body {
    display: grid;
    gap: var(--space-8);
  }
  .profile-main {
    min-width: 0;
  }
  @media (min-width: 980px) {
    .profile-body {
      grid-template-columns: minmax(0, 40rem) 14rem;
      align-items: start;
      gap: var(--space-12);
    }
    .profile-main {
      grid-column: 1;
      grid-row: 1;
    }
    .ataglance {
      grid-column: 2;
      grid-row: 1;
      position: sticky;
      top: var(--space-8);
    }
  }
  .ataglance {
    border-top: 2px solid var(--ink);
    padding-top: var(--space-3);
  }
  .ag-head {
    font-family: var(--font-label);
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-muted);
    margin: 0 0 var(--space-3);
  }
  .ag-list {
    margin: 0;
    display: grid;
    gap: var(--space-3);
  }
  .ag-list div {
    display: grid;
    gap: 2px;
  }
  .ag-list dt {
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-faint);
  }
  .ag-list dd {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--ink);
  }
  .verified {
    font-weight: 600;
  }
  .summary {
    margin: 0 0 var(--space-6);
  }
  .lead-row {
    padding: var(--space-6) 0;
    border-top: 1px solid var(--hairline);
  }
  .lead-row.has-gauge {
    display: grid;
    gap: var(--space-6) var(--space-8);
  }
  @media (min-width: 720px) {
    .lead-row.has-gauge {
      grid-template-columns: minmax(0, 18rem) minmax(0, 1fr);
      align-items: start;
    }
  }
  .lead-col {
    min-width: 0;
  }
  .block {
    padding: var(--space-6) 0;
    border-top: 1px solid var(--hairline);
  }
  .block h2,
  .lead-row h2 {
    font-family: var(--font-label);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--ink-muted);
    font-weight: 400;
    margin-bottom: var(--space-3);
  }
  .data {
    margin: 0;
    display: grid;
    gap: var(--space-3);
  }
  .data dt {
    font-size: 0.78rem;
    color: var(--ink-muted);
  }
  .data dd {
    margin: 0;
  }
  .hybrid {
    margin: 0;
    font-size: 1.05rem;
  }
  .reg-list {
    list-style: none;
    margin: 0 0 var(--space-3);
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }
  .reg-list li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2) var(--space-3);
  }
  .reg-name {
    font-weight: 600;
  }
  .reg-tags {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-shrink: 0;
  }
  .reg-level,
  .reg-status {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
    white-space: nowrap;
  }
  .reg-status.is-binding {
    color: var(--ink);
    font-weight: 600;
  }
  .legal-status {
    margin: 0 0 var(--space-3);
    font-size: 0.9rem;
    color: var(--ink-muted);
  }
  .legal-status strong {
    color: var(--ink);
  }
  .obligation {
    margin: 0;
  }
  .actors,
  .docs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }
  .actor-name {
    font-weight: 600;
  }
  .profile a {
    color: var(--ink);
    text-decoration-color: var(--hairline);
    text-underline-offset: 2px;
  }
  .profile a:hover {
    text-decoration-color: var(--ink);
  }
  .actor-role {
    display: block;
    font-size: 0.85rem;
    color: var(--ink-muted);
  }
  .docs li {
    display: grid;
    gap: 2px;
  }
  .doc-meta {
    font-size: 0.78rem;
    color: var(--ink-muted);
  }
  .target {
    font-size: 0.8rem;
    color: var(--ink-muted);
    margin-top: var(--space-2);
  }
  .empty {
    color: var(--ink-muted);
    font-style: italic;
    margin: 0;
  }
  .profile-cta {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--hairline);
    font-size: var(--text-sm);
    color: var(--ink-muted);
  }
  .profile-cta a {
    color: var(--ink);
    white-space: nowrap;
  }
</style>
